{
  "projectName": "MyExpoApp",
  "projectType": "expo",
  "bundleIdentifier": "com.company.myexpoapp",
  "primaryLanguage": "en",
  "techStack": {
    "platform": "Expo",
    "language": "TypeScript",
    "framework": "Expo SDK 51+",
    "router": "Expo Router",
    "styling": "NativeWind (Tailwind)",
    "stateManagement": "Zustand",
    "networking": "TanStack Query",
    "storage": "Expo SQLite",
    "testing": "Jest + Detox",
    "build": "EAS Build"
  },
  "projectStage": "planning",
  "codingStandards": {
    "language": "en",
    "namingConvention": "camelCase",
    "indentation": "spaces-2",
    "lineLength": 100
  },
  "createdDate": "{{DATE}}",
  "lastUpdated": "{{DATE}}",
  "automation": {
    "telegram": {
      "enabled": true,
      "chatId": "",
      "topicId": "",
      "triggers": {
        "git_push": true,
        "task_complete": false,
        "deploy": true
      }
    },
    "trello": {
      "enabled": true,
      "autoSync": true,
      "triggers": {
        "task_complete": true,
        "milestone": true,
        "blocked": true
      }
    },
    "git": {
      "autoCommit": true,
      "autoPush": true
    }
  }
}
